// Available variables which can be used inside of strings.
// ${workspaceRoot}: the root folder of the team
// ${file}: the current opened file
// ${fileBasename}: the current opened file's basename
// ${fileDirname}: the current opened file's dirname
// ${fileExtname}: the current opened file's extension
// ${cwd}: the current working directory of the spawned process
// A task runner that calls a custom npm script that compiles the extension.
{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "compile",
			"group": "build",
			"dependsOn": [
				"compile:client",
				"compile:server"
			],
			"problemMatcher": []
		},
		{
			"label": "compile:client",
			"type": "npm",
			"script": "compile:client",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "compile:server",
			"type": "npm",
			"script": "compile:server",
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": [
				"$tsc"
			]
		},
		{
			"label": "watch",
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"dependsOn": [
				"watch:client",
				"watch:server"
			],
			"problemMatcher": []
		},
		{
			"label": "watch:client",
			"type": "npm",
			"script": "esbuild-watch:client",
			"isBackground": true,
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": {
				"owner": "esbuild-client",
				"source": "esbuild",
				"fileLocation": ["relative", "${workspaceFolder}/phpcs"],
				"pattern": [
					{
						"regexp": "^\\s+(.+):(\\d+):(\\d+):\\s+(ERROR|WARNING|error|warning):\\s+(.+)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started$",
					"endsPattern": "^\\[watch\\] build finished$"
				}
			}
		},
		{
			"label": "watch:server",
			"type": "npm",
			"script": "esbuild-watch:server",
			"isBackground": true,
			"group": "build",
			"presentation": {
				"panel": "dedicated",
				"reveal": "never"
			},
			"problemMatcher": {
				"owner": "esbuild-server",
				"source": "esbuild",
				"fileLocation": ["relative", "${workspaceFolder}/phpcs-server"],
				"pattern": [
					{
						"regexp": "^\\s+(.+):(\\d+):(\\d+):\\s+(ERROR|WARNING|error|warning):\\s+(.+)$",
						"file": 1,
						"line": 2,
						"column": 3,
						"severity": 4,
						"message": 5
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\[watch\\] build started$",
					"endsPattern": "^\\[watch\\] build finished$"
				}
			}
		}
	]
}
