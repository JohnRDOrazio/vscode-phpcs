{
	"compilerOptions": {
		"noUnusedLocals": true,
		"noUnusedParameters": true,
		"noImplicitAny": true,
		"noImplicitReturns": true,
		"target": "ES2022",
		"module": "commonjs",
		"moduleResolution": "node",
		"sourceMap": true,
		"lib": [ "ES2022" ],
		"outDir": "../phpcs/server",
		"skipLibCheck": true
	},
	"ts-node": {
		"compilerOptions": {
			"module": "commonjs"
		}
	},
	"exclude": [
		"node_modules"
	]
}
